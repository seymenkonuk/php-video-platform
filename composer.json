{
    "name": "seymenkonuk/php-video-platform",
    "description": "PHP ile geliştirilmiş YouTube benzeri video paylaşım platformu.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Recep Seymen Konuk",
            "email": "konukrecepseymen@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "config/",
            "Routes\\": "routes/",
            "Database\\Seeders\\": "database/seeders"
        }
    },
    "require": {
        "seymenkonuk/framework": "^1.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.0"
    },
    "scripts": {
        "autoload": "composer dump-autoload --optimize --strict-psr --strict-ambiguous",
        "test": "phpunit --testdox --colors=always",
        "phpstan": "phpstan analyse",
        "check": [
            "@autoload",
            "@phpstan",
            "@test"
        ],
        "seed": "php database/seeders/main.php"
    }
}