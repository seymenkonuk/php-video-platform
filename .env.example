# =========================
# APP CONFIG
# =========================
APP_NAME=AppName
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

# =========================
# DATABASE (MySQL)
# =========================
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=app
DB_CHARSET=utf8mb4
DB_USERNAME=app
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# =========================
# REDIS
# =========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# =========================
# LOGGING
# =========================
LOG_LEVEL=debug
